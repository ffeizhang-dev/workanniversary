rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Employee photos
    match /employee_photos/{organizationId}/{fileName} {
      // Allow read if user belongs to the organization
      allow read: if request.auth != null;

      // Allow write if user is admin or editor in the organization
      allow write: if request.auth != null &&
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.organizationId == organizationId &&
                     firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ['admin', 'editor'];

      // Allow delete if user is admin
      allow delete: if request.auth != null &&
                      firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.organizationId == organizationId &&
                      firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
